# ===== ملف إعدادات البيئة =====
# انسخ هذا الملف وسمّيه .env.local
# لا ترفع هذا الملف على GitHub أبداً

# ===== مطلوب تغييره =====
# اعمل كلمة سر عشوائية - مثال: اكتب في terminal:
# openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MIN_32_CHARS

# ===== روابط الفيديوهات =====
# ارفع الفيديوهات على Bunny.net أو Cloudflare R2
# ثم ضع الروابط هنا
VIDEO_1_URL=https://your-cdn.b-cdn.net/lesson-1.mp4
VIDEO_2_URL=https://your-cdn.b-cdn.net/lesson-2.mp4
VIDEO_3_URL=https://your-cdn.b-cdn.net/lesson-3.mp4
VIDEO_4_URL=https://your-cdn.b-cdn.net/lesson-4.mp4
